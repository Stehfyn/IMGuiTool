{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": { "IMGUITOOL_STATIC_RUNTIME": "ON" }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    },
    {
      "name": "macos-base",
      "hidden": true,
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
    },
    {
      "name": "msvc",
      "displayName": "MSVC",
      "inherits": "windows-base",
      "cacheVariables": { "CMAKE_C_COMPILER": "cl", "CMAKE_CXX_COMPILER": "cl" }
    },
    {
      "name": "clang-cl",
      "displayName": "Clang-cl",
      "inherits": "windows-base",
      "cacheVariables": { "CMAKE_C_COMPILER": "clang-cl", "CMAKE_CXX_COMPILER": "clang-cl" }
    },
    {
      "name": "mingw",
      "displayName": "MinGW-w64 GCC",
      "inherits": "windows-base",
      "cacheVariables": { "CMAKE_C_COMPILER": "gcc", "CMAKE_CXX_COMPILER": "g++" }
    },
    {
      "name": "vs",
      "displayName": "Visual Studio 2026 (x64)",
      "inherits": "windows-base",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64"
    },
    {
      "name": "linux-gcc",
      "displayName": "Linux GCC",
      "inherits": "linux-base",
      "cacheVariables": { "CMAKE_C_COMPILER": "gcc", "CMAKE_CXX_COMPILER": "g++" }
    },
    {
      "name": "linux-clang",
      "displayName": "Linux Clang",
      "inherits": "linux-base",
      "cacheVariables": { "CMAKE_C_COMPILER": "clang", "CMAKE_CXX_COMPILER": "clang++" }
    },
    {
      "name": "macos-clang",
      "displayName": "macOS Clang",
      "inherits": "macos-base",
      "cacheVariables": { "CMAKE_C_COMPILER": "clang", "CMAKE_CXX_COMPILER": "clang++" }
    }
  ],
  "buildPresets": [
    { "name": "msvc-debug",        "configurePreset": "msvc",        "configuration": "Debug" },
    { "name": "msvc-release",      "configurePreset": "msvc",        "configuration": "Release" },
    { "name": "clang-cl-debug",    "configurePreset": "clang-cl",    "configuration": "Debug" },
    { "name": "clang-cl-release",  "configurePreset": "clang-cl",    "configuration": "Release" },
    { "name": "mingw-debug",       "configurePreset": "mingw",       "configuration": "Debug" },
    { "name": "mingw-release",     "configurePreset": "mingw",       "configuration": "Release" },
    { "name": "vs-debug",          "configurePreset": "vs",          "configuration": "Debug" },
    { "name": "vs-release",        "configurePreset": "vs",          "configuration": "Release" },
    { "name": "linux-gcc-debug",    "configurePreset": "linux-gcc",   "configuration": "Debug" },
    { "name": "linux-gcc-release",  "configurePreset": "linux-gcc",   "configuration": "Release" },
    { "name": "linux-clang-debug",  "configurePreset": "linux-clang", "configuration": "Debug" },
    { "name": "linux-clang-release","configurePreset": "linux-clang", "configuration": "Release" },
    { "name": "macos-clang-debug",  "configurePreset": "macos-clang", "configuration": "Debug" },
    { "name": "macos-clang-release","configurePreset": "macos-clang", "configuration": "Release" }
  ]
}
